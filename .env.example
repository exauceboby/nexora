MONGO_URL=mongodb+srv://user:password@cluster.mongodb.net/nexora_db
DB_NAME=nexora_db
AUTH_SECRET=change-me-with-a-long-random-secret

# Public app configuration. Leave empty until the real server/domain is chosen.
APP_DOMAIN=
NEXT_PUBLIC_APP_DOMAIN=
NEXT_PUBLIC_SITE_URL=
CORS_ORIGINS=

# Payment provider placeholders.
# Connect these to Orange Money, M-Pesa, Airtel Money, Stripe, PayDunya, Flutterwave, CinetPay, or another provider.
PAYMENT_PROVIDER=MANUAL_MOBILE_MONEY
PAYMENT_API_KEY=
PAYMENT_WEBHOOK_SECRET=

# Optional email provider used by the existing API.
RESEND_API_KEY=
EMAIL_FROM=
CONTACT_EMAIL=
SUPPORT_PHONE=
